doctype html
html(lang="en")
  head
    meta(charset="utf-8")
    meta(name="viewport" content="width=device-width, initial-scale=1")
    meta(name="description" content="crumbun is a tiny Bun fullstack engine with file routes and Pug templates.")
    title crumbun
    link(rel="icon" href="/favicon.svg")
    link(rel="preload" as="image" href="/crumbun-board.png")
    link(rel="stylesheet" href="/_crumbun/style.css")
  body
    header.topbar
      a.brand(href="#top" aria-label="crumbun home")
        span.brand-mark c
        span crumbun
      nav.nav(aria-label="Main")
        a(href="#start") Start
        a(href="#shape") Shape
        a(href="#api") API
        a(href="#publish") Publish
    main#top
      section.hero
        img.hero-art(src="/crumbun-board.png" alt="")
        div.hero-copy
          p.kicker Bun + Pug + file routes
          h1 crumbun
          p.lede A tiny fullstack engine for apps that want server routes, Pug views, and almost nothing else.
          div.actions
            a.button.primary(href="#start") Get started
            a.button.secondary(href="#shape") See the shape
          pre.command
            code bunx create-crumbun my-app
        div.scroll-hint(aria-hidden="true") ↓

      section#start.band
        div.section-head
          p.kicker Start
          h2 One command, one server file.
          p Create an app, install packages, and run Bun directly.
        div.quick-grid
          article.step
            span.step-num 01
            h3 Scaffold
            pre
              code bunx create-crumbun my-app
          article.step
            span.step-num 02
            h3 Run
            pre
              code.
                cd my-app
                bun install
                bun run dev
          article.step
            span.step-num 03
            h3 Ship the boring parts
            p Routes live in files. Views stay in Pug. Static files stay in public.

      section#shape.surface
        div.section-head
          p.kicker Shape
          h2 The filesystem is the map.
          p Bracket folders become params. Page files export HTTP handlers.
        div.shape-grid
          pre.file-tree
            code.
              public/
                favicon.svg
              src/
                api/
                  story/
                    [id]/
                      page.ts
                      getstory.ts
                views/
                  story/
                    story.pug
                    story.css
                  index.pug
                  style.css
          div.route-table
            div.route-row
              span file
              code src/api/story/[id]/page.ts
            div.route-row
              span route
              code /story/:id
            div.route-row
              span view
              code render("story/story")
            div.route-row
              span css
              code /_crumbun/story/story.css

      section#api.band
        div.section-head
          p.kicker API
          h2 Handlers return web responses or plain values.
          p Use the platform first. crumbun only fills the routing and rendering gap.
        div.code-pair
          pre
            code.
              import type { PageContext } from "crumbun";

              export async function GET({ params, render }: PageContext) {
                return render("story/story", {
                  title: `Story ${params.id}`,
                });
              }
          ul.api-list
            li #[code request] is the incoming Request.
            li #[code params] comes from bracket folders.
            li #[code render()] resolves Pug files in src/views.
            li Return #[code Response], strings, objects, or nothing.

      section#publish.closing
        p.kicker Publish
        h2 Small enough to read before lunch.
        p crumbun ships as the engine plus a scaffold CLI. No hidden dev server, no client build pipeline, no framework ceremony.
        div.actions
          a.button.primary(href="https://www.npmjs.com/package/crumbun") npm: crumbun
          a.button.secondary(href="https://www.npmjs.com/package/create-crumbun") npm: create-crumbun

    footer.footer
      span crumbun
      span Bun fullstack, kept small.
