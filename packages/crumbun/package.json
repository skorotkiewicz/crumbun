{
  "name": "crumbun",
  "version": "0.3.0",
  "description": "Tiny Bun fullstack engine with file routes, Pug templates, and static export.",
  "type": "module",
  "homepage": "https://sekor.eu.org/crumbun/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skorotkiewicz/crumbun.git",
    "directory": "packages/crumbun"
  },
  "main": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "types": "./src/index.ts",
  "files": [
    "src/index.ts",
    "README.md"
  ],
  "scripts": {
    "test": "bun test",
    "pack:check": "npm pack --dry-run --json",
    "prepublishOnly": "bun test"
  },
  "keywords": [
    "bun",
    "pug",
    "fullstack",
    "router",
    "templates"
  ],
  "license": "MIT",
  "engines": {
    "bun": ">=1.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "pug": "^3.0.4"
  }
}
