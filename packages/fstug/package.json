{
  "name": "fstug",
  "version": "0.1.0",
  "description": "Tiny Bun fullstack engine with file routes and Pug templates.",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
